      "targets": [
        {
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"subsystem\"] == \"STORAGE\")\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({Subsystem: \"CDH\", Files: r.CDH_NUM_FILES, Size: r.CDH_DIR_SIZE}))\n  |> union(other: (from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"subsystem\"] == \"STORAGE\")\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({Subsystem: \"EPS\", Files: r.EPS_NUM_FILES, Size: r.EPS_DIR_SIZE}))))\n  |> union(other: (from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"subsystem\"] == \"STORAGE\")\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({Subsystem: \"ADCS\", Files: r.ADCS_NUM_FILES, Size: r.ADCS_DIR_SIZE}))))\n  |> union(other: (from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"subsystem\"] == \"STORAGE\")\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({Subsystem: \"COMMS\", Files: r.COMMS_NUM_FILES, Size: r.COMMS_DIR_SIZE}))))\n  |> union(other: (from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"subsystem\"] == \"STORAGE\")\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({Subsystem: \"GPS\", Files: r.GPS_NUM_FILES, Size: r.GPS_DIR_SIZE}))))\n  |> union(other: (from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"subsystem\"] == \"STORAGE\")\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({Subsystem: \"PAYLOAD\", Files: r.PAYLOAD_NUM_FILES, Size: r.PAYLOAD_DIR_SIZE}))))\n  |> union(other: (from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"subsystem\"] == \"STORAGE\")\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({Subsystem: \"CMD_LOGS\", Files: r.CMD_LOGS_NUM_FILES, Size: r.CMD_LOGS_DIR_SIZE}))))\n  |> sort(columns: [\"Subsystem\"])",
